# Newsletter provider configuration for /api/subscribe
# Pick ONE provider by setting NEWSLETTER_PROVIDER, then fill in the matching credentials.
# If NEWSLETTER_PROVIDER is unset or "log", submissions are logged to the server console only.

# Options: log | formspree | resend | mailchimp | buttondown | convertkit
NEWSLETTER_PROVIDER=log

# --- Cloudflare Turnstile (optional) ---
# If both are set, the newsletter form will render a Turnstile widget and the API
# route will verify tokens server-side. Leave unset to skip Turnstile entirely
# (the honeypot + time-trap still apply).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA_your_site_key
# TURNSTILE_SECRET_KEY=0x4AAAAAAA_your_secret_key

# --- Formspree ---
# Get a form ID at https://formspree.io (Project -> form endpoint, the part after /f/)
# FORMSPREE_FORM_ID=xxxxxxxx

# --- Resend (audiences) ---
# https://resend.com/audiences
# RESEND_API_KEY=re_xxx
# RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Mailchimp ---
# API key from Account -> Extras -> API keys. Audience ID is the List ID in Audience settings.
# MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us21
# MAILCHIMP_AUDIENCE_ID=xxxxxxxxxx

# --- Buttondown ---
# https://buttondown.email
# BUTTONDOWN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- ConvertKit ---
# https://app.convertkit.com/account_settings/advanced_settings
# CONVERTKIT_API_KEY=xxxxxxxxxxxxxxxxxxxx
# CONVERTKIT_FORM_ID=1234567

# Contact form configuration for /api/contact
# Options: log | formspree | resend
CONTACT_PROVIDER=log

# --- Formspree (contact) ---
# Separate form for contact submissions (so you can route them differently).
# CONTACT_FORMSPREE_FORM_ID=xxxxxxxx

# --- Resend (contact) ---
# Uses RESEND_API_KEY (defined above for newsletter) and sends an email.
# CONTACT_FROM_EMAIL=hello@pause-health.ai
# CONTACT_TO_EMAIL=hello@pause-health.ai

# --- Salesforce Agentforce / Embedded Messaging for Web ---
# All four values are surfaced in the Salesforce Setup screen under:
#   Setup -> Embedded Service Deployments -> <your deployment> -> Code Snippet
# They are public deployment metadata (designed to ship in client JS) so it is
# safe to expose them as NEXT_PUBLIC_ vars. Set all four to enable the live
# Agentforce Service Agent on /demo/intake; leave any unset to fall back to the
# Pause-branded scripted intake prototype.
#
# NEXT_PUBLIC_AGENTFORCE_ORG_ID=00Dxx0000000000AAA
# NEXT_PUBLIC_AGENTFORCE_DEPLOYMENT_NAME=Pause_Health_Intake
# NEXT_PUBLIC_AGENTFORCE_SITE_URL=https://your-domain.my.site.com/ESWYourDeploymentName1700000000000
# NEXT_PUBLIC_AGENTFORCE_SCRT2_URL=https://your-domain.my.salesforce-scrt.com

# --- Pause Care Router (Anthropic) ---
# Optional. When ANTHROPIC_API_KEY is set, the Care Router agent at
#   POST /api/agents/care-router/tasks
# calls Anthropic Claude via the @anthropic-ai/sdk. When unset, the
# Care Router falls back to a deterministic Pause policy engine that
# implements the same clinical pathway rubric. Either way the agent
# emits A2A-conformant responses and Agent Fabric trace spans.
#
# PAUSE_CARE_ROUTER_MODEL defaults to claude-sonnet-4-5-20250929 and
# must remain on the model allow-list enforced by the Pause Agent
# Fabric (claude-sonnet-* or claude-opus-* prefixes).
#
# ANTHROPIC_API_KEY=sk-ant-...
# PAUSE_CARE_ROUTER_MODEL=claude-sonnet-4-5-20250929

# --- Salesforce Org (real Data 360 grounding for the Care Router) ---
# All three must be set together for the real-org grounding path to activate.
# If any is missing, the Care Router falls back to the deterministic mocked
# grounding in lib/data-360.ts (zero-credential default works locally and in
# every Vercel preview).
#
# Source: Salesforce Setup -> External Client App Manager -> <your app> ->
#         Settings -> OAuth Settings -> Consumer Key and Secret.
# Auth flow: OAuth 2.0 Client Credentials Flow (server-to-server, no user
# redirect). Configured per the policy in Setup -> External Client Apps ->
# Policies (Run-As user must be set and pre-authorized via permission set).
#
# SF_INSTANCE_URL must NOT have a trailing slash. Use the org's My Domain
# URL (e.g. https://yourorg.my.salesforce.com), not login.salesforce.com.
#
# SF_INSTANCE_URL=https://trailsignup-c2d761a3b89bf2.my.salesforce.com
# SF_CLIENT_ID=3MVG9...
# SF_CLIENT_SECRET=ABCDEF...
#
# Optional override; defaults to v60.0 if unset. Bumping this is safe as
# long as the SOQL in lib/salesforce/grounding.ts stays version-compatible.
# SF_API_VERSION=60.0
