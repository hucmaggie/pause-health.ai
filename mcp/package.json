{
  "name": "@pause-health/mcp",
  "version": "0.3.0",
  "description": "Model Context Protocol (MCP) server that exposes the Pause-Health.ai MuleSoft Experience APIs as tools for AI agents (Claude Desktop, Cursor, Agentforce, and any MCP-compliant client).",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "bin": {
    "pause-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "smoke": "node scripts/smoke.mjs",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
