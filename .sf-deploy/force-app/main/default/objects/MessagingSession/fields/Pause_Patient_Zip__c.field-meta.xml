<?xml version="1.0" encoding="UTF-8"?>
<!--
  Carries the patient's ZIP handed in-band via hidden prechat into the
  conversation. Routing Flow writes it here; the bot context variable
  Pause_Patient_Zip reads it; the Find-a-Provider action's zip input maps to
  $Context.Pause_Patient_Zip. Length 10 to allow ZIP+4.
  Deploy:  cd .sf-deploy && sf project deploy start --source-dir force-app --target-org trailsignup
-->
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Pause_Patient_Zip__c</fullName>
    <label>Pause Patient Zip</label>
    <type>Text</type>
    <length>10</length>
    <required>false</required>
    <externalId>false</externalId>
    <trackHistory>false</trackHistory>
    <description>Patient 5-digit ZIP handed in-band via hidden prechat; mapped to bot context $Context.Pause_Patient_Zip and the Find-a-Provider action zip input.</description>
</CustomField>
