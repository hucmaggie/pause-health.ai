<?xml version="1.0" encoding="UTF-8"?>
<!--
  Retrieve the metadata we need to make the Patient_Zip prechat handoff
  deployable. Run from .sf-deploy (it has its own sfdx-project.json):

    cd .sf-deploy
    sf project retrieve start --manifest manifest/package.xml --target-org trailsignup

  Files land under force-app/main/default/. After retrieve, the agent edits
  add Patient_Zip; then redeploy with:

    sf project deploy start --source-dir force-app --target-org trailsignup

  If a member name is wrong for your org, list the real ones with e.g.
    sf org list metadata --metadata-type MessagingChannel --target-org trailsignup
-->
<Package xmlns="http://soap.sforce.com/2006/04/metadata">
    <types>
        <members>Pause_Intake_Prechat_Router</members>
        <name>Flow</name>
    </types>
    <types>
        <members>Messaging_for_In_App_Web</members>
        <name>MessagingChannel</name>
    </types>
    <types>
        <members>Pause_Health_Intake_Prechat_Dossier</members>
        <name>PermissionSet</name>
    </types>
    <version>62.0</version>
</Package>
