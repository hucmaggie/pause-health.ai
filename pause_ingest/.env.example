# --- JupyterHealth Exchange connection ---
# Local dev default; point at your customer's deployment for staging/prod.
JHE_BASE_URL=http://localhost:8000

# OAuth client created under Django Admin → Django OAuth Toolkit → Applications.
# Use the "client credentials" grant for a service-to-service ingest worker.
JHE_CLIENT_ID=
JHE_CLIENT_SECRET=

# FHIR identifiers obtained from JHE after creating a Patient and Data Source.
JHE_PATIENT_FHIR_ID=
JHE_DATA_SOURCE_ID=

# Default timezone for daily-aggregate omh-shim conversions (step_count, sleep_duration, etc.).
# Use the patient's local zone in production; UTC is fine for smoke tests.
PAUSE_INGEST_DEFAULT_TZ=UTC
