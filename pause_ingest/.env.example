# --- JupyterHealth Exchange connection ---
# Local dev default; point at your customer's deployment for staging/prod.
JHE_BASE_URL=http://localhost:8000

# OAuth client created under Django Admin → Django OAuth Toolkit → Applications.
# Use the "client credentials" grant for a service-to-service ingest worker.
JHE_CLIENT_ID=
JHE_CLIENT_SECRET=

# FHIR identifiers obtained from JHE after creating a Patient and Data Source.
JHE_PATIENT_FHIR_ID=
JHE_DATA_SOURCE_ID=

# FhirSource id (the JHE-assigned pk of a `core.FhirSource` row tying
# this Patient to this Data Source). Required by JHE's auxiliary handler
# when uploading derived/non-OMH observations (e.g. our HRV features
# under https://pause-health.ai/schemas/derived); ignored by the mapped
# OMH handler. Leave blank if you only upload raw OMH observations.
JHE_FHIR_SOURCE_ID=

# Default timezone for daily-aggregate omh-shim conversions (step_count, sleep_duration, etc.).
# Use the patient's local zone in production; UTC is fine for smoke tests.
PAUSE_INGEST_DEFAULT_TZ=UTC

# --- Salesforce Data Cloud Ingestion API (Phase 2 hardening) ---
# Used by examples/data_cloud_push.py to push wearable feature rows into the
# Data Cloud Ingestion API connector that feeds the three Calculated Insights.
# Reuses the same Connected App as the frontend SOQL / CI read path; the app
# must additionally carry the cdp_ingest_api OAuth scope.
# See docs/PHASE_2_INGESTION_API_RUNBOOK.md.
SF_INSTANCE_URL=
SF_CLIENT_ID=
SF_CLIENT_SECRET=
# Ingestion API connector + object API names (defaults match the runbook).
SF_DC_INGEST_CONNECTOR=Pause_Wearable
SF_DC_INGEST_OBJECT=wearable_feature
