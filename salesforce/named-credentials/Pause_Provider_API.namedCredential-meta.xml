<?xml version="1.0" encoding="UTF-8"?>
<!--
  Named Credential for the External Service that backs the Agentforce
  "Find a provider" action. Points at the public, no-auth Pause provider
  directory Experience endpoint (https://pause-health.ai/api/mulesoft/providers).

  This is the LEGACY no-authentication Named Credential form — the simplest
  deployable artifact for a public GET. Newer orgs that enforce the
  External Credential model can instead create an External Credential with
  Authentication Protocol = Custom (no principal) and a Named Credential that
  references it; see docs/AGENTFORCE_PROVIDER_ACTION_RUNBOOK.md for that path.

  When you stand up the live MuleSoft Experience API, repoint <endpoint> at
  the gateway/CloudHub base URL (and add the bearer/JWT auth there).
-->
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Pause Provider API</label>
    <endpoint>https://pause-health.ai</endpoint>
    <principalType>Anonymous</principalType>
    <protocol>NoAuthentication</protocol>
    <generateAuthorizationHeader>false</generateAuthorizationHeader>
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>false</allowMergeFieldsInHeader>
</NamedCredential>
